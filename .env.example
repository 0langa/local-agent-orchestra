# Agentheim runtime env is no longer used for AI provider/model configuration.
# Configure AI providers with:
#   agentheim provider add <provider-id> --template <template-id> --model <model-id>
#   agentheim provider assign <role> --provider <provider-id> --model <model-id>
#
# One-time migration from older env layouts:
#   agentheim provider import-env

# API server auth
# AI_TEAM_API_KEYS=replace-with-api-key
# AI_TEAM_DEV_MODE=false

# Optional API/Web CORS
# AGENTHEIM_CORS_ORIGINS=http://localhost,http://127.0.0.1

# Optional config/vault locations for CI or portable installs
# AGENTHEIM_CONFIG_DIR=
# AGENTHEIM_DATA_DIR=
# AGENTHEIM_SECRET_BACKEND=file
# AGENTHEIM_VAULT_PASSPHRASE=

# External SDK credential chains are still provider-owned.
# Examples:
# AWS_REGION=eu-central-1
# AWS_PROFILE=default
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# OCI_CONFIG_FILE=C:\Users\you\.oci\config

# Optional feature flags unrelated to provider auth
AI_TEAM_ENABLE_GITHUB=false
AI_TEAM_ENABLE_MCP=false
AI_TEAM_ENABLE_WEB=false
